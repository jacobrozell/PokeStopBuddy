"guide.process.intro" = "Nominating a PokéStop happens inside Pokémon GO (or the Wayfarer website). PokeStop Buddy helps you draft the text before you paste it in.";
"guide.process.section.prerequisites.heading" = "Before you start";
"guide.process.section.prerequisites.body" = "You need an eligible Pokémon GO account and to be physically near the location you want to nominate.";
"guide.process.callout.requirements.title" = "Access requirements";
"guide.process.callout.requirements.body" = "Niantic may change level and onboarding requirements. Check the official Pokémon GO help center for the latest rules.";
"guide.process.section.steps.heading" = "The nine steps";
"guide.process.step.1" = "Open Main Menu → Settings → Uploads → New PokéStop.";
"guide.process.step.2" = "Place the pin on the object — not where you're standing.";
"guide.process.step.3" = "Take a clear main photo of the nominated object.";
"guide.process.step.4" = "Take a supporting photo showing the surrounding area.";
"guide.process.step.5" = "Enter the title and description (paste from PokeStop Buddy).";
"guide.process.step.6" = "Choose a category tag that best fits the location.";
"guide.process.step.7" = "Preview everything before you continue.";
"guide.process.step.8" = "Add supporting information explaining why it's eligible.";
"guide.process.step.9" = "Upload now or later — then community reviewers evaluate it.";
"guide.process.buddy" = "Draft title, description, and supporting text here first. Use Copy all when you're ready to paste into steps 5 and 8.";

"guide.fields.intro" = "Some fields exist only in PokeStop Buddy to help generation. Others paste directly into Pokémon GO.";
"guide.fields.section.inputs.heading" = "Drafting inputs";
"guide.fields.row.placeName" = "Place name — your working name; becomes the generated title.";
"guide.fields.row.category" = "Category — matches Step 6; shapes description wording.";
"guide.fields.row.style" = "Writing style — app-only tone (concise, descriptive, formal).";
"guide.fields.row.keyFeatures" = "Key features — short bullets fed into the description generator.";
"guide.fields.row.eligibility" = "Eligibility — pick at least one pillar for the supporting statement.";
"guide.fields.row.locationHint" = "How to find it — paste into supporting info to help reviewers.";
"guide.fields.row.accessNotes" = "Access notes — pedestrian access, hours, or safety context.";
"guide.fields.section.generated.heading" = "Generated content (paste into GO)";
"guide.fields.row.title" = "Title — Step 5, max 100 characters.";
"guide.fields.row.description" = "Description — Step 5, max 250 characters.";
"guide.fields.row.supporting" = "Supporting statement — Step 8 additional information.";
"guide.fields.buddy" = "Generate after filling inputs, then edit any field manually before copying.";

"guide.categories.intro" = "Pokémon GO asks you to categorize the location. Pick the closest match — it helps reviewers understand the nomination.";
"guide.categories.section.picker.heading" = "In Pokémon GO";
"guide.categories.section.picker.body" = "Choose from tags like Library, Public Art, or Other. If nothing fits, select Other and explain in the description.";
"guide.categories.section.reference.heading" = "Category reference";
"guide.categories.section.reference.body" = "Tap a category to see example key features and which eligibility pillars usually apply.";
"guide.categories.buddy" = "The Category picker in the editor matches these tags and tunes generated descriptions.";
"guide.categories.examples.publicArt" = "e.g. hand-painted mural, bronze sculpture, 2019 commission";
"guide.categories.examples.historicalMarker" = "e.g. erected 1952, commemorates founding of the town";
"guide.categories.examples.monument" = "e.g. war memorial, dedicated 1920, granite obelisk";
"guide.categories.examples.building" = "e.g. Art Deco facade, listed landmark, built 1931";
"guide.categories.examples.placeOfWorship" = "e.g. historic chapel, open to visitors on weekends";
"guide.categories.examples.library" = "e.g. Carnegie library, Little Free Library on public sidewalk";
"guide.categories.examples.park" = "e.g. neighborhood park, playground and picnic area";
"guide.categories.examples.playground" = "e.g. public playground, rubber surface, city-maintained";
"guide.categories.examples.trailhead" = "e.g. Riverside Trail marker, 4-mile loop";
"guide.categories.examples.sportsField" = "e.g. community ball field, public hours posted";
"guide.categories.examples.fountain" = "e.g. plaza fountain, centerpiece of town square";
"guide.categories.examples.garden" = "e.g. community garden, public beds and paths";
"guide.categories.examples.localBusiness" = "e.g. longtime local landmark — avoid generic chain stores";
"guide.categories.examples.other" = "Use when no tag fits; explain what it is in key features and description";

"guide.eligibility.intro" = "Every nomination must meet at least one of Niantic's three eligibility pillars. Eligibility alone doesn't guarantee acceptance.";
"guide.eligibility.section.pillars.heading" = "The three pillars";
"guide.eligibility.pillar.historicCultural" = "Exploration — historic, cultural, or educational significance; teaches about the community.";
"guide.eligibility.pillar.exercise" = "Exercise — encourages walking, sports, or outdoor activity.";
"guide.eligibility.pillar.socialExploration" = "Social — a gathering place to meet, explore, or share an experience.";
"guide.eligibility.section.rules.heading" = "Rules of thumb";
"guide.eligibility.rule.oneRequired" = "Select at least one pillar that genuinely applies.";
"guide.eligibility.rule.notEnough" = "Meeting a pillar is necessary but not sufficient — acceptance criteria still apply.";
"guide.eligibility.rule.noGameMentions" = "Never mention Pokémon GO or ask reviewers to approve your nomination.";
"guide.eligibility.callout.mistakes.title" = "Common rejections";
"guide.eligibility.callout.mistakes.body" = "K–12 school grounds, private residences, temporary objects, emergency services, and duplicates too close to existing Wayspots.";
"guide.eligibility.buddy" = "Use Why is it eligible? in the editor — selections feed the supporting statement generator.";

"guide.photos.intro" = "Photos and pin placement happen only in Pokémon GO. Good visuals help reviewers confirm the location exists.";
"guide.photos.section.pin.heading" = "Pin placement";
"guide.photos.section.pin.body" = "Drag the pin onto the object you're nominating. A misplaced pin is a common reason for rejection.";
"guide.photos.section.main.heading" = "Main photo";
"guide.photos.tip.main.clear" = "Well-lit, in focus, and close enough to identify the object.";
"guide.photos.tip.main.close" = "Show the nominated feature — not just a distant building.";
"guide.photos.tip.main.noFaces" = "Avoid identifiable faces and license plates when possible.";
"guide.photos.section.supporting.heading" = "Supporting photo";
"guide.photos.section.supporting.body" = "Show the surroundings so reviewers can verify the location on maps or Street View.";
"guide.photos.buddy" = "Use How to find it and Access notes to explain what photos can't show (gated access, rear entrance, etc.).";

"guide.copyWorkflow.intro" = "After drafting in PokeStop Buddy, copy your text into Pokémon GO at the right steps.";
"guide.copyWorkflow.section.steps.heading" = "Recommended workflow";
"guide.copyWorkflow.step.1" = "Fill in place name, category, features, and eligibility in the editor.";
"guide.copyWorkflow.step.2" = "Tap Generate content and review the Quality coach.";
"guide.copyWorkflow.step.3" = "Fine-tune text or regenerate until blockers are resolved.";
"guide.copyWorkflow.step.4" = "Tap Copy all (or Share) in the editor.";
"guide.copyWorkflow.step.5" = "In Pokémon GO, paste into Title and Description at Step 5.";
"guide.copyWorkflow.step.6" = "Paste the supporting statement at Step 8, then complete photos and upload.";
"guide.copyWorkflow.callout.uploadLater.title" = "Weak signal?";
"guide.copyWorkflow.callout.uploadLater.body" = "Choose Upload Later in Pokémon GO and submit when you're on Wi‑Fi.";
"guide.copyWorkflow.buddy" = "Save your draft in the library so you can iterate before visiting the site.";

